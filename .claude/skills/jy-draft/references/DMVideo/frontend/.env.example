# 环境变量配置的模板文件，复制此文件为    .env.development    或    .env.production

# 服务器基础 URL 配置
# 不同环境使用不同的 API 地址
# 开发环境示例: http://127.0.0.1:8205
# 生产环境示例: https://test.dmaodata.cn
SERVER_BASE_URL=https://test.dmaodata.cn

# Token API 基础地址（用于 Token 相关接口调用）
# 开发环境示例: http://127.0.0.1:8205
# 生产环境示例: https://test.dmaodata.cn
API_BASE_URL=http://127.0.0.1:8205

# 认证 Token（可选，用于开发调试）
# AUTH_TOKEN=your_token_here
